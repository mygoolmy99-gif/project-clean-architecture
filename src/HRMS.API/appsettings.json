{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Tenants": [
    {
      "Id": "11111111-1111-1111-1111-111111111111",
      "Name": "Acme Corp",
      "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=HRMS_AcmeCorp;Trusted_Connection=True;MultipleActiveResultSets=true"
    },
    {
      "Id": "22222222-2222-2222-2222-222222222222",
      "Name": "Globex Inc",
      "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=HRMS_GlobexInc;Trusted_Connection=True;MultipleActiveResultSets=true"
    }
  ],
  "Jwt": {
    "Key": "SuperSecretProductionKeyThatIsAtLeast32BytesLong!",
    "Issuer": "HRMS_Issuer",
    "Audience": "HRMS_Audience"
  },
  "AllowedOrigins": [ "https://app.hrms.example.com" ]
}
